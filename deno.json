{
	"workspace": [
		"./packages/astro-snapshot",
		"./tests/fixture"
	],
	"tasks": {
		"upgrade-interactive": {
			"description": "Upgrade all dependencies interactively.",
			"command": "deno outdated --interactive --update --latest"
		},
		"test": {
			"description": "Run all integration tests.",
			"command": "deno test --allow-run=deno --allow-read=tests/fixture/ --allow-write=tests/fixture/ tests/"
		}
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 120,
		"singleQuote": true
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended",
				"workspace",
				"jsr"
			]
		}
	},
	"compilerOptions": {
		"strict": true,
		"checkJs": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"allowScripts": [
		"npm:puppeteer"
	],
	"nodeModulesDir": "auto",
	"imports": {
		"astro": "npm:astro@^6.0.5"
	}
}
